# Base RPC Configuration
RPC_URL=https://mainnet.base.org
RPC_TIMEOUT=30

# Hydrex Contract Addresses
VOTER_ADDRESS=0xc69E3eF39E3fFBcE2A1c570f8d3ADF76909ef17b
# VoterV5 contract address on Base

# Your Configuration
MY_ESCROW_ADDRESS=0x0000000000000000000000000000000000000000
YOUR_VOTING_POWER=1000000
# Voting power in the same units as contract

# API Keys (Optional)
COINGECKO_API_KEY=
# Free tier works, but pro key recommended for better rate limits

# Database
DATABASE_PATH=data/db/data.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=hydrex_optimizer.log

# Cache Settings
PRICE_CACHE_TTL=300
# Cache token prices for 5 minutes

# Optimization Settings
MIN_VOTE_ALLOCATION=1000
# Minimum votes to allocate to any single gauge
MAX_GAUGES_TO_VOTE=10
# Maximum number of gauges to split votes across

# Auto top-k sweep settings (used by auto_voter / boundary_monitor)
AUTO_TOP_K_ENABLED=true
AUTO_TOP_K_MAX=50
AUTO_TOP_K_CANDIDATE_POOLS=60
AUTO_TOP_K_RETURN_TOLERANCE_PCT=2.0
AUTO_VOTE_RESOLVE_POOL_NAMES=false
AUTO_VOTE_TRIGGER_BLOCKS_BEFORE=20
AUTO_VOTE_SECOND_TRIGGER_BLOCKS_BEFORE=5
AUTO_VOTE_MAX_GAS_PRICE_GWEI=10
AUTO_VOTE_SECOND_MAX_GAS_PRICE_GWEI=20
